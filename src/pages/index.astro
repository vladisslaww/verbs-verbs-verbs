---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout title="Conjugaison">
  <div class="card">
    <div class="header">
      <h1>Conjugaison</h1>
      <div class="verb" id="verb">—</div>
      <div class="translation" id="translation">—</div>
      <div class="tense" id="tense">—</div>
    </div>

    <div class="form-grid" id="form-grid">
      <div class="input-row">
        <label class="pronoun" for="f0">je / j'</label>
        <div class="input-wrapper" id="w0">
          <input type="text" id="f0" autocomplete="off" autocapitalize="none" spellcheck="false" enterkeyhint="next" />
        </div>
      </div>
      <div class="input-row">
        <label class="pronoun" for="f1">tu</label>
        <div class="input-wrapper" id="w1">
          <input type="text" id="f1" autocomplete="off" autocapitalize="none" spellcheck="false" enterkeyhint="next" />
        </div>
      </div>
      <div class="input-row">
        <label class="pronoun" for="f2">il / elle / on</label>
        <div class="input-wrapper" id="w2">
          <input type="text" id="f2" autocomplete="off" autocapitalize="none" spellcheck="false" enterkeyhint="next" />
        </div>
      </div>
      <div class="input-row">
        <label class="pronoun" for="f3">nous</label>
        <div class="input-wrapper" id="w3">
          <input type="text" id="f3" autocomplete="off" autocapitalize="none" spellcheck="false" enterkeyhint="next" />
        </div>
      </div>
      <div class="input-row">
        <label class="pronoun" for="f4">vous</label>
        <div class="input-wrapper" id="w4">
          <input type="text" id="f4" autocomplete="off" autocapitalize="none" spellcheck="false" enterkeyhint="next" />
        </div>
      </div>
      <div class="input-row">
        <label class="pronoun" for="f5">ils / elles</label>
        <div class="input-wrapper" id="w5">
          <input type="text" id="f5" autocomplete="off" autocapitalize="none" spellcheck="false" enterkeyhint="send" />
        </div>
      </div>
    </div>

    <button class="btn" id="check-btn" type="button">Vérifier</button>

    <div class="countdown-bar" id="countdown">
      <div class="fill" id="countdown-fill"></div>
    </div>

    <div class="round-score" id="round-score"></div>
    <div class="score" id="score"></div>
    <div class="hint">Entrée pour vérifier</div>
  </div>

  <script>
    import { initQuiz } from "../scripts/quiz.ts";
    initQuiz();
  </script>
</Layout>
